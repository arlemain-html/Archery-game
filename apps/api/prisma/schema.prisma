generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String?
  xp         Int      @default(0)
  level      Int      @default(1)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  walletAccounts   WalletAccount[]
  profile          Profile?
  sessions         Session[]
  inventory        Inventory[]
  inventoryTxs     InventoryTransaction[]
  matchHistory     MatchPlayer[]
  seasonPassClaims SeasonPassClaim[]
}

model WalletAccount {
  id             String   @id @default(uuid())
  wallet_address String   @unique
  user_id        String
  user           User     @relation(fields: [user_id], references: [id])
  created_at     DateTime @default(now())

  @@index([wallet_address])
}

model Profile {
  id             String   @id @default(uuid())
  user_id        String   @unique
  user           User     @relation(fields: [user_id], references: [id])
  avatar_url     String?
  bio            String?
  elo_rating     Int      @default(1000)
  matches_played Int      @default(0)
  matches_won    Int      @default(0)
  updated_at     DateTime @updatedAt
}

model Nonce {
  nonce          String   @id
  wallet_address String
  expires_at     DateTime
  created_at     DateTime @default(now())

  @@index([wallet_address])
}

model Session {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id])
  refresh_token String
  expires_at    DateTime
  created_at    DateTime @default(now())
}

model Inventory {
  id               String   @id @default(uuid())
  user_id          String
  user             User     @relation(fields: [user_id], references: [id])
  item_id          String
  token_id         String?
  quantity         Int      @default(0)
  is_nft           Boolean  @default(false)
  contract_address String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([user_id, item_id, token_id])
}

model InventoryTransaction {
  id               String   @id @default(uuid())
  user_id          String
  user             User     @relation(fields: [user_id], references: [id])
  item_id          String
  amount           Int
  transaction_type String
  created_at       DateTime @default(now())
}

model Match {
  id         String    @id @default(uuid())
  season_id  String
  match_type String
  status     String
  started_at DateTime  @default(now())
  ended_at   DateTime?

  players MatchPlayer[]
}

model SeasonPassClaim {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  level      Int
  reward_id  String
  created_at DateTime @default(now())

  @@unique([user_id, level])
}

model MatchPlayer {
  id                  String  @id @default(uuid())
  match_id            String
  match               Match   @relation(fields: [match_id], references: [id])
  user_id             String?
  user                User?   @relation(fields: [user_id], references: [id])
  is_ghost            Boolean @default(false)
  score_achieved      Int     @default(0)
  accuracy_percentage Decimal @default(0.0)
  elo_change          Int     @default(0)
  equipped_snapshot   Json?
}
